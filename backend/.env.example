# =============================================
# IWIS Backend - Environment Variables Template
# =============================================
# NEVER commit .env to git. Copy this file to .env and fill in real values.
# Add all secrets to Render dashboard Environment Variables instead.

# Primary Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...your_primary_key_here

# Backup Gemini API Keys (optional, for fallback if quota exceeded)
GEMINI_API_KEY_2=AIza...your_backup_key_2_here
GEMINI_API_KEY_3=AIza...your_backup_key_3_here

# Email (Nodemailer / Gmail App Password for password reset)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# JWT Secret (generate a strong random string, e.g. openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS - set to your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Node environment
NODE_ENV=development
