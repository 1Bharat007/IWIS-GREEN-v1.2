# ============================================
# IWIS Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---
JWT_SECRET=your_super_secret_jwt_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server ---
PORT=5000
NODE_ENV=development
DB_PATH=./iwis.db

# --- AI (Optional backup keys for rotation) ---
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# --- RAG (EcoBot Knowledge Base) ---
ENABLE_RAG=true

# --- Email (OTP & Password Reset) ---
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# --- SMS Gateway (OTP) ---
# Available providers: email | android
# In production, this defaults to email if omitted.
SMS_PROVIDER=email
SMS_GATEWAY_URL=http://192.168.1.100:8080/v1/sms/send
SMS_GATEWAY_API_KEY=your_android_gateway_api_key

# --- Frontend URL (CORS whitelist) ---
FRONTEND_URL=http://localhost:3000

# --- Features ---
ENABLE_PHONE_OTP=false